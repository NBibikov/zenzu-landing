---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { t } from '../i18n'

interface Props {
  title: string
}

const { title } = Astro.props
const locale = 'en'
const strings = t(locale)
---

<BaseLayout title={`${title} — Zenzu`}>
  <Header t={strings} locale={locale} />
  <main class="pt-24 pb-20 px-6">
    <article class="max-w-3xl mx-auto prose prose-headings:text-moss-dark prose-a:text-moss prose-strong:text-moss-dark">
      <h1>{title}</h1>
      <p class="text-on-surface-muted text-sm">Last updated: April 6, 2026</p>
      <slot />
    </article>
  </main>
  <Footer t={strings} locale={locale} />
</BaseLayout>
