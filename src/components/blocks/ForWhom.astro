---
interface Props { t: any }
const { t } = Astro.props

const forItems: string[] = [t.forWhom.for1, t.forWhom.for2, t.forWhom.for3, t.forWhom.for4]
const notForItems: string[] = [t.forWhom.notFor1, t.forWhom.notFor2, t.forWhom.notFor3]
---

<section class="py-20 px-6 bg-surface-dim">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-moss-dark mb-4">{t.forWhom.title}</h2>
      <p class="text-on-surface-muted text-lg max-w-2xl mx-auto leading-relaxed">{t.forWhom.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-moss-container/40 rounded-2xl p-8 border border-moss/20">
        <h3 class="font-bold text-moss-dark text-lg mb-6 flex items-center gap-2">
          <span class="w-6 h-6 rounded-full bg-moss flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </span>
          {t.forWhom.forLabel}
        </h3>
        <ul class="space-y-4">
          {forItems.map((item) => (
            <li class="flex items-start gap-3 text-on-surface text-sm leading-relaxed">
              <span class="w-1.5 h-1.5 rounded-full bg-moss mt-2 flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-sand-dark/50 rounded-2xl p-8 border border-sand-dark">
        <h3 class="font-bold text-warm text-lg mb-6 flex items-center gap-2">
          <span class="w-6 h-6 rounded-full bg-warm/20 border border-warm/30 flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-warm" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </span>
          {t.forWhom.notForLabel}
        </h3>
        <ul class="space-y-4">
          {notForItems.map((item) => (
            <li class="flex items-start gap-3 text-on-surface-muted text-sm leading-relaxed">
              <span class="w-1.5 h-1.5 rounded-full bg-warm/50 mt-2 flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
