---
interface Props { t: any }
const { t } = Astro.props
---

<section class="relative py-20 px-6 bg-moss overflow-hidden">
  <img src="/koi.png" alt="" class="absolute -bottom-8 -left-8 w-48 opacity-15 pointer-events-none select-none" />
  <img src="/stone.png" alt="" class="absolute -top-4 -right-8 w-36 opacity-10 pointer-events-none select-none" />
  <div class="relative max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">{t.cta.title}</h2>
    <p class="text-moss-light text-lg mb-10 leading-relaxed">{t.cta.subtitle}</p>
    <a
      href="https://app.zenzu.app"
      class="inline-block bg-white text-moss-dark px-10 py-4 rounded-full text-lg font-bold hover:bg-sand transition-colors shadow-lg"
    >
      {t.cta.button}
    </a>
  </div>
</section>
