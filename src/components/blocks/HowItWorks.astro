---
interface Props { t: any }
const { t } = Astro.props

const steps = [
  { step: '01', ...t.howItWorks.step1 },
  { step: '02', ...t.howItWorks.step2 },
  { step: '03', ...t.howItWorks.step3 },
]
---

<section id="how-it-works" class="relative py-20 px-6">
  <img src="/bridge.png" alt="" class="absolute bottom-0 right-0 w-64 opacity-8 pointer-events-none select-none" />
  <div class="relative max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-moss-dark mb-4">{t.howItWorks.title}</h2>
      <p class="text-on-surface-muted text-lg">{t.howItWorks.subtitle}</p>
    </div>

    <div class="space-y-12">
      {steps.map(({ step, title, desc }) => (
        <div class="flex items-start gap-6">
          <div class="flex-shrink-0 w-12 h-12 bg-moss-container rounded-full flex items-center justify-center">
            <span class="text-moss-dark font-bold text-sm">{step}</span>
          </div>
          <div>
            <h3 class="font-bold text-xl text-moss-dark mb-2">{title}</h3>
            <p class="text-on-surface-muted leading-relaxed">{desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
