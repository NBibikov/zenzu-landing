---
interface Props { t: any }
const { t } = Astro.props

// Zenzu Supabase project (public anon key — RLS allows public SELECT only).
const SUPABASE_URL = 'https://vomksfxhelvowvtcfhoh.supabase.co'
const SUPABASE_ANON =
  'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZvbWtzZnhoZWx2b3d2dGNmaG9oIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5NjY4NTgsImV4cCI6MjA5MDU0Mjg1OH0.AjJSyFxPIjz_y1gTFZsGg3Q9GDIgi1OxZv-s_n3SCHY'
---

<section class="py-20 px-6 bg-sand" id="news-preview">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center text-2xl font-bold text-moss-dark mb-3">{t.news.title}</h2>
    <p class="text-center text-on-surface-muted mb-12 max-w-2xl mx-auto">{t.news.subtitle}</p>

    <div
      id="news-grid"
      class="grid grid-cols-1 md:grid-cols-3 gap-6"
      data-empty={t.news.empty}
    >
      {/* Skeleton placeholders — replaced on the client once news loads. */}
      {[0, 1, 2, 3, 4, 5].map(() => (
        <div class="rounded-xl bg-white/60 border border-moss/10 p-5 animate-pulse">
          <div class="h-4 w-20 bg-moss/15 rounded mb-3"></div>
          <div class="h-4 w-full bg-moss/10 rounded mb-2"></div>
          <div class="h-4 w-2/3 bg-moss/10 rounded"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline define:vars={{ SUPABASE_URL, SUPABASE_ANON }}>
  (async () => {
    const grid = document.getElementById('news-grid')
    if (!grid) return
    const emptyMsg = grid.dataset.empty || 'No news yet'

    const labelFor = (c) => {
      if (!c) return ''
      const lower = c.toLowerCase()
      if (lower === 'it') return 'IT'
      if (lower === 'llm') return 'LLM'
      return c.charAt(0).toUpperCase() + c.slice(1)
    }

    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/news_items?select=id,category,headline_en,source_name&order=published_at.desc&limit=6`,
        { headers: { apikey: SUPABASE_ANON, Authorization: `Bearer ${SUPABASE_ANON}` } },
      )
      if (!res.ok) throw new Error(`HTTP ${res.status}`)
      const items = await res.json()

      if (!Array.isArray(items) || items.length === 0) {
        grid.innerHTML = `<p class="col-span-full text-center text-on-surface-muted">${emptyMsg}</p>`
        return
      }

      grid.innerHTML = items
        .map(
          (it) => `
        <div class="rounded-xl bg-white border border-moss/10 p-5 flex flex-col">
          <span class="inline-block self-start text-xs font-semibold text-moss bg-moss/10 rounded px-2 py-0.5 mb-3">
            ${labelFor(it.category)}
          </span>
          <p class="text-on-surface font-medium leading-snug flex-1">${
            (it.headline_en || '').replace(/</g, '&lt;')
          }</p>
          <p class="text-on-surface-muted text-xs mt-4">${(it.source_name || '').replace(/</g, '&lt;')}</p>
        </div>`,
        )
        .join('')
    } catch (e) {
      grid.innerHTML = `<p class="col-span-full text-center text-on-surface-muted">${emptyMsg}</p>`
    }
  })()
</script>
