---
const features = [
  {
    icon: '🎬',
    title: 'YouTube Videos',
    description: 'Watch with synced subtitles. Tap any word to see translation instantly. Add to your deck with one tap.',
  },
  {
    icon: '🎙️',
    title: 'Podcasts',
    description: 'AI-transcribed episodes with word-level highlighting. Follow along as you listen and learn.',
  },
  {
    icon: '📚',
    title: 'AI Courses',
    description: 'Personalized grammar and vocabulary lessons generated by AI. Exercises adapt to your level.',
  },
  {
    icon: '🧠',
    title: 'FSRS-5 Spaced Repetition',
    description: 'Science-backed algorithm schedules reviews at the optimal time. Remember words forever, not just for a test.',
  },
  {
    icon: '🔊',
    title: 'Native Pronunciation',
    description: 'Cloud TTS for every word and sentence. Hear how it sounds from day one.',
  },
  {
    icon: '📷',
    title: 'Import from Anywhere',
    description: 'Text, photos, articles — paste or snap anything. AI extracts vocabulary matched to your level.',
  },
]
---

<section id="features" class="py-20 px-6 bg-sand">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-moss-dark mb-4">
        Everything you need to learn
      </h2>
      <p class="text-on-surface-muted text-lg max-w-2xl mx-auto">
        One app for all your language learning content. Import what you love, learn what matters.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map(({ icon, title, description }) => (
        <div class="bg-surface rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <span class="text-3xl mb-4 block">{icon}</span>
          <h3 class="font-bold text-lg text-moss-dark mb-2">{title}</h3>
          <p class="text-on-surface-muted text-sm leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
