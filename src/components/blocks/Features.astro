---
interface Props { t: any }
const { t } = Astro.props

const features = [
  { icon: '🎬', ...t.features.youtube },
  { icon: '🎙️', ...t.features.podcasts },
  { icon: '📚', ...t.features.courses },
  { icon: '🧠', ...t.features.srs },
  { icon: '🔊', ...t.features.tts },
  { icon: '📷', ...t.features.import },
]
---

<section id="features" class="py-20 px-6 bg-sand">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-moss-dark mb-4">{t.features.title}</h2>
      <p class="text-on-surface-muted text-lg max-w-2xl mx-auto">{t.features.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map(({ icon, title, desc }) => (
        <div class="bg-surface rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <span class="text-3xl mb-4 block">{icon}</span>
          <h3 class="font-bold text-lg text-moss-dark mb-2">{title}</h3>
          <p class="text-on-surface-muted text-sm leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
