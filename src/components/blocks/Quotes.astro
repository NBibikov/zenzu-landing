---
interface Props { t: any }
const { t } = Astro.props

const quotes = [
  { text: t.quotes.quote1Text, author: t.quotes.quote1Author },
  { text: t.quotes.quote2Text, author: t.quotes.quote2Author },
  { text: t.quotes.quote3Text, author: t.quotes.quote3Author },
]
---

<section class="py-20 px-6 bg-sand">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-center text-2xl font-bold text-moss-dark mb-14">{t.quotes.title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {quotes.map(({ text, author }) => (
        <div class="flex flex-col">
          <svg class="w-8 h-8 text-moss/30 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 32 32">
            <path d="M10 8C5.6 8 2 11.6 2 16s3.6 8 8 8h2v-4h-2c-2.2 0-4-1.8-4-4 0-2.2 1.8-4 4-4h2V8h-2zm14 0c-4.4 0-8 3.6-8 8s3.6 8 8 8h2v-4h-2c-2.2 0-4-1.8-4-4 0-2.2 1.8-4 4-4h2V8h-2z"/>
          </svg>
          <p class="text-on-surface text-base leading-relaxed italic flex-1 mb-6">{text}</p>
          <p class="text-on-surface-muted text-sm font-medium">— {author}</p>
        </div>
      ))}
    </div>
  </div>
</section>
