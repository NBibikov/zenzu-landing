---
import { localeNames, supportedLocales, localePath, type Locale } from '../../i18n'

interface Props {
  t: any
  locale: Locale
}
const { t, locale } = Astro.props
---

<header class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-lg border-b border-sand-dark/50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={localePath('/', locale)} class="flex items-center gap-2 font-bold text-lg text-moss-dark">
      <img src="/zenzu-icon.png" alt="Zenzu" class="w-8 h-8 rounded-lg" />
      Zenzu
    </a>

    <!-- Nav links (desktop) -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#features" class="text-sm text-on-surface-muted hover:text-moss transition-colors">
        {t.nav.features}
      </a>
      <a href="#how-it-works" class="text-sm text-on-surface-muted hover:text-moss transition-colors">
        {t.nav.howItWorks}
      </a>

      <!-- Language switcher -->
      <div class="relative group">
        <button class="text-sm text-on-surface-muted hover:text-moss transition-colors flex items-center gap-1">
          {localeNames[locale]?.slice(0, 4)}
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full right-0 mt-1 bg-surface border border-sand-dark rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all py-1 min-w-36">
          {supportedLocales.map((loc) => (
            <a
              href={localePath('/', loc)}
              class={`block px-4 py-2 text-sm hover:bg-sand transition-colors ${loc === locale ? 'text-moss font-semibold' : 'text-on-surface-muted'}`}
            >
              {localeNames[loc]}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA -->
    <a
      href="https://app.zenzu.app"
      class="bg-moss text-white px-5 py-2 rounded-full text-sm font-semibold hover:bg-moss-dark transition-colors"
    >
      {t.nav.getStarted}
    </a>
  </nav>
</header>
