---
import { getCollection } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import Header from '../../../components/layout/Header.astro'
import Footer from '../../../components/layout/Footer.astro'
import BlogCard from '../../../components/blog/BlogCard.astro'
import { t, type Locale } from '../../../i18n'

export async function getStaticPaths() {
  const allEntries = await getCollection('blog')
  const locales = ['uk', 'de', 'fr', 'es', 'pt'] as const

  return locales.map(lang => {
    const entries = allEntries
      .filter(e => e.id.endsWith(`/${lang}`))
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    return { params: { lang }, props: { entries } }
  })
}

const { lang } = Astro.params
const { entries } = Astro.props

const locale = lang as Locale
const strings = t(locale)

const site = Astro.site!.toString().replace(/\/$/, '')
const blogLocales = ['en', 'uk', 'de', 'fr', 'es', 'pt'] as const
const alternates = blogLocales.map(loc => ({
  hreflang: loc,
  href: loc === 'en' ? `${site}/blog/` : `${site}/${loc}/blog/`,
}))
---

<BaseLayout
  title={`${strings.blog.title} — Zenzu`}
  ogTitle={strings.blog.title}
  description={strings.blog.subtitle}
  lang={locale}
  alternates={alternates}
>
  <Header t={strings} locale={locale} />
  <main class="pt-24 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-bold text-moss-dark">{strings.blog.title}</h1>
        <p class="mt-3 text-lg text-on-surface-muted">{strings.blog.subtitle}</p>
      </div>

      {entries.length === 0 ? (
        <p class="text-center text-on-surface-muted py-20">{strings.blog.noArticles}</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {entries.map(entry => {
            const [slug] = entry.id.split('/')
            return (
              <BlogCard
                slug={slug}
                title={entry.data.title}
                excerpt={entry.data.excerpt}
                date={entry.data.date}
                image={entry.data.image}
                locale={locale}
                readMore={strings.blog.readMore}
              />
            )
          })}
        </div>
      )}
    </div>
  </main>
  <Footer t={strings} locale={locale} />
</BaseLayout>
